{
  "namingConventions": {
    "appliedConventionKeyNamingConvention": "CamelCase",
    "createConventionKeyNamingConvention": "PascalCase",
    "fileExtensionNamingConvention": "LowerCase",
    "fileNameNamingConvention": "PascalCase",
    "folderNameNamingConvention": "PascalCase"
  },
  "appBehavior": {
    "autogenerateFileNamesByConvention": true,
    "autogenerateFolderNamesByConvention": true,
    "sortAttributeLists": "OrdinalIgnoreCase",
    "sortClassificationsList": "OrdinalIgnoreCase",
    "sortConventionsList": "OrdinalIgnoreCase"
  },
  "editorPreferences": {
    "tabSize": 4,
    "insertSpaces": true,
    "detectIndentation": false,
    "trimAutoWhitespace": true,
    "autoIndent": "Advanced"
  },
  "metadataImporterSettings": {
    "allowNoDataConnection": true,
    "allowNoDatastore": true,
    "allowNoLocation": true,
    "mergeClassifications": true,
    "mergeExtensions": true,
    "mergeTemplateMappings": true,
    "removeOrphanDataItems": true,
    "removeOrphanDataObjectsInDataConnection": false,
    "removeOrphanDataObjectsInDatastore": false,
    "updateDataConnections": false,
    "updateDataItems": true,
    "updateDataObjectMappings": true,
    "updateDataObjects": true
  }
}