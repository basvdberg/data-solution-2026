{
  "name": "OData v4 demo (Northwind)",
  "notes": "Smoke-test config pointing at the canonical public OData v4 reference service (Northwind). Used to verify lib/odata.py + lib/parquet.py end-to-end on machines where the real CBS feed (datasets.cbs.nl) is firewalled.",
  "classifications": [
    { "classification": "source:northwind-demo" },
    { "classification": "protocol:odata_v4" }
  ],
  "extensions": [
    { "key": "default_odata_page_size", "value": "100" }
  ],
  "dataObjectMappings": [
    {
      "id": "odata-demo-regions",
      "name": "Northwind Regions to 000_Source landing (demo)",
      "enabled": true,
      "classifications": [
        { "classification": "interface_type:odata_v4" },
        { "classification": "trigger:source_change" }
      ],
      "extensions": [
        { "key": "odata_page_size", "value": "100" },
        { "key": "landing_path_template", "value": "./Data/000_Source/{dataset}/{table}/{date}.parquet" }
      ],
      "sourceDataObjects": [
        {
          "name": "Regions",
          "dataConnection": {
            "name": "odata-demo-northwind",
            "extensions": [
              { "key": "base_url", "value": "https://services.odata.org/V4/Northwind/Northwind.svc" }
            ]
          }
        }
      ],
      "targetDataObject": {
        "name": "Northwind",
        "dataConnection": {
          "name": "source-landing",
          "extensions": [
            { "key": "path", "value": "./Data/000_Source/Northwind" }
          ]
        }
      }
    }
  ]
}
