{
  "$schema": "../../../schema/data-solution-metadata.schema.json",
  "id": "source/openmeteo/daily-temperature",
  "notes": "Open-Meteo Forecast API daily mean 2 m temperature — https://open-meteo.com/en/docs",
  "dataConnectionId": "connection/open-meteo-forecast",
  "dataItems": [
    {
      "id": "source/openmeteo/daily-temperature/station_id",
      "name": "station_id",
      "notes": "Reference station code for a Netherlands location.",
      "ordinalPosition": 1,
      "dataType": "string"
    },
    {
      "id": "source/openmeteo/daily-temperature/observed_property",
      "name": "observed_property",
      "notes": "Open-Meteo daily variable name (e.g. temperature_2m_mean).",
      "ordinalPosition": 2,
      "dataType": "string"
    },
    {
      "id": "source/openmeteo/daily-temperature/latitude",
      "name": "latitude",
      "ordinalPosition": 3,
      "dataType": "double"
    },
    {
      "id": "source/openmeteo/daily-temperature/longitude",
      "name": "longitude",
      "ordinalPosition": 4,
      "dataType": "double"
    },
    {
      "id": "source/openmeteo/daily-temperature/period_begin",
      "name": "period_begin",
      "ordinalPosition": 5,
      "dataType": "string"
    },
    {
      "id": "source/openmeteo/daily-temperature/period_end",
      "name": "period_end",
      "ordinalPosition": 6,
      "dataType": "string"
    },
    {
      "id": "source/openmeteo/daily-temperature/timestamp",
      "name": "timestamp",
      "ordinalPosition": 7,
      "dataType": "string"
    },
    {
      "id": "source/openmeteo/daily-temperature/value",
      "name": "value",
      "notes": "Daily mean 2 m air temperature in degrees Celsius.",
      "ordinalPosition": 8,
      "dataType": "double"
    }
  ],
  "refreshContract": {
    "triggerMode": "time",
    "timeTrigger": { "schedule": "@hourly" },
    "refreshScope": "all",
    "notes": "Every hour potentially the full table is refreshed."
  }
}
