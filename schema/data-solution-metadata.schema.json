{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/data-solution-2026/schema/data-solution-metadata.schema.json",
  "title": "Data Solution Metadata Artifact Schema",
  "description": "Schema for data-solution-2026 metadata artifacts stored in connection/, data-object/, and data-object-mapping/.",
  "oneOf": [
    { "$ref": "#/definitions/connectionArtifact" },
    { "$ref": "#/definitions/dataObjectArtifact" },
    { "$ref": "#/definitions/dataObjectMappingArtifact" }
  ],
  "definitions": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    },
    "extension": {
      "type": "object",
      "required": ["key"],
      "additionalProperties": false,
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "value": { "type": ["string", "number", "boolean", "null"] },
        "notes": { "$ref": "#/definitions/notes" }
      }
    },
    "classification": {
      "type": "object",
      "required": ["classification"],
      "additionalProperties": false,
      "properties": {
        "group": { "type": "string" },
        "classification": { "type": "string", "minLength": 1 },
        "scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "$ref": "#/definitions/notes" }
      }
    },
    "dataItem": {
      "type": "object",
      "required": ["id", "name", "ordinalPosition", "dataType"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/id" },
        "name": { "type": "string", "minLength": 1 },
        "notes": { "$ref": "#/definitions/notes" },
        "ordinalPosition": { "type": "integer", "minimum": 1 },
        "dataType": { "type": "string", "minLength": 1 },
        "isPrimaryKey": { "type": "boolean" },
        "isNullable": { "type": "boolean" },
        "characterLength": { "type": "integer", "minimum": 0 },
        "numericPrecision": { "type": "integer", "minimum": 0 },
        "numericScale": { "type": "integer", "minimum": 0 },
        "queryCode": { "type": "string" },
        "queryLanguage": { "type": "string" },
        "classifications": {
          "type": "array",
          "items": { "$ref": "#/definitions/classification" }
        },
        "extensions": {
          "type": "array",
          "items": { "$ref": "#/definitions/extension" }
        }
      }
    },
    "dependencyTrigger": {
      "type": "object",
      "required": ["upstreamDataObjectId", "signal"],
      "additionalProperties": false,
      "properties": {
        "upstreamDataObjectId": { "$ref": "#/definitions/id" },
        "signal": { "type": "string", "minLength": 1 },
        "notes": { "$ref": "#/definitions/notes" }
      }
    },
    "timeTrigger": {
      "type": "object",
      "required": ["schedule"],
      "additionalProperties": false,
      "properties": {
        "schedule": { "type": "string", "minLength": 1 },
        "timezone": { "type": "string" },
        "notes": { "$ref": "#/definitions/notes" }
      }
    },
    "refreshContract": {
      "type": "object",
      "required": ["triggerMode", "refreshScope"],
      "additionalProperties": false,
      "properties": {
        "triggerMode": { "type": "string", "minLength": 1 },
        "timeTrigger": { "$ref": "#/definitions/timeTrigger" },
        "dependencyTriggers": {
          "type": "array",
          "items": { "$ref": "#/definitions/dependencyTrigger" }
        },
        "refreshScope": {
          "type": "string",
          "enum": ["all", "subset", "partition"]
        },
        "notes": { "$ref": "#/definitions/notes" }
      }
    },
    "dataItemRef": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/id" }
      }
    },
    "dataItemMapping": {
      "type": "object",
      "required": ["id", "sourceDataItems", "targetDataItem"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/definitions/id" },
        "name": { "type": "string" },
        "sourceDataItems": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/dataItemRef" }
        },
        "targetDataItem": { "$ref": "#/definitions/dataItemRef" },
        "notes": { "$ref": "#/definitions/notes" },
        "extensions": {
          "type": "array",
          "items": { "$ref": "#/definitions/extension" }
        }
      }
    },
    "connectionArtifact": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "$schema": { "type": "string" },
        "id": {
          "allOf": [
            { "$ref": "#/definitions/id" },
            { "pattern": "^connection/.+" }
          ]
        },
        "name": { "type": "string", "minLength": 1 },
        "notes": { "$ref": "#/definitions/notes" },
        "extensions": {
          "type": "array",
          "items": { "$ref": "#/definitions/extension" }
        },
        "classifications": {
          "type": "array",
          "items": { "$ref": "#/definitions/classification" }
        }
      }
    },
    "dataObjectArtifact": {
      "type": "object",
      "required": ["id", "dataConnectionId", "dataItems"],
      "additionalProperties": false,
      "properties": {
        "$schema": { "type": "string" },
        "id": {
          "allOf": [
            { "$ref": "#/definitions/id" },
            { "not": { "pattern": "^connection/.+" } },
            { "not": { "pattern": "^data-object-mapping/.+" } }
          ]
        },
        "notes": { "$ref": "#/definitions/notes" },
        "dataConnectionId": {
          "type": "string",
          "pattern": "^connection/.+"
        },
        "dataItems": {
          "type": "array",
          "items": { "$ref": "#/definitions/dataItem" }
        },
        "classifications": {
          "type": "array",
          "items": { "$ref": "#/definitions/classification" }
        },
        "extensions": {
          "type": "array",
          "items": { "$ref": "#/definitions/extension" }
        },
        "refreshContract": { "$ref": "#/definitions/refreshContract" }
      }
    },
    "dataObjectMappingArtifact": {
      "type": "object",
      "required": [
        "id",
        "enabled",
        "sourceDataObjectIds",
        "targetDataObjectId",
        "dataItemMappings"
      ],
      "additionalProperties": false,
      "properties": {
        "$schema": { "type": "string" },
        "id": {
          "allOf": [
            { "$ref": "#/definitions/id" },
            { "pattern": "^data-object-mapping/.+" }
          ]
        },
        "enabled": { "type": "boolean" },
        "notes": { "$ref": "#/definitions/notes" },
        "sourceDataObjectIds": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/id" }
        },
        "targetDataObjectId": { "$ref": "#/definitions/id" },
        "dataItemMappings": {
          "type": "array",
          "items": { "$ref": "#/definitions/dataItemMapping" }
        },
        "classifications": {
          "type": "array",
          "items": { "$ref": "#/definitions/classification" }
        },
        "extensions": {
          "type": "array",
          "items": { "$ref": "#/definitions/extension" }
        }
      }
    }
  }
}
