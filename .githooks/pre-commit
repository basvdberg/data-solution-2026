#!/bin/sh
# Regenerate Markdown table of contents and project structure, then stage updates.
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

PYTHON=""
for candidate in python3 python py; do
  if command -v "$candidate" >/dev/null 2>&1; then
    PYTHON="$candidate"
    break
  fi
done

if [ -z "$PYTHON" ]; then
  echo "pre-commit: python not found; install Python 3 to run scripts/update_markdown_docs.py" >&2
  exit 1
fi

"$PYTHON" scripts/update_markdown_docs.py
"$PYTHON" scripts/update_prompts.py

# Re-stage Markdown files updated by the hook so they are included in this commit.
git diff --name-only -- '*.md' | while IFS= read -r file; do
  [ -n "$file" ] || continue
  git add -- "$file"
done

exit 0
