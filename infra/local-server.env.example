# Local server settings for this PoC (copy to local-server.env on your workstation).
# Load before SSH examples:  set -a && source infra/local-server.env && set +a
# Do not commit local-server.env (machine-specific).

# SSH from your workstation to the local server
LOCAL_SERVER_SSH_USER=bas
LOCAL_SERVER_SSH_HOST=basnas
LOCAL_SERVER_SSH=bas@basnas

# LAN address of the local server
LOCAL_SERVER_LAN_IP=192.168.2.2

# Local DNS zone for HTTPS service URLs (LAN / VPN only)
LOCAL_SERVER_DNS_ZONE=basnas

# HTTPS URLs via NGINX on the local server
LOCAL_SERVER_URL_AIRFLOW=https://airflow.basnas/
LOCAL_SERVER_URL_KAFKA=https://kafka.basnas/

# Host ports when HTTPS is not configured yet
LOCAL_SERVER_PORT_AIRFLOW=8081
LOCAL_SERVER_PORT_KAFKA_UI=8085
