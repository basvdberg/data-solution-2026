# Copy to .env and adjust on NAS. Do not commit .env (secrets).

# Airflow 3 UI login (user: admin). Change on NAS before exposing the UI.
AIRFLOW_ADMIN_PASSWORD=changeme

# Linux owner for mounted volumes (id -u on NAS)
AIRFLOW_UID=1000

# Absolute path to data-solution-2026 clone on the host
DATA_SOLUTION_ROOT=../../

# Published host port for Airflow UI (HTTPS URL: see ../local-server.env.example)
AIRFLOW_HOST_PORT=8081

# Metadata Postgres (shared basnas_postgress container on immich_default)
POSTGRES_HOST=basnas_postgress:5432
POSTGRES_DOCKER_NETWORK=immich_default
# Use DATA_SOLUTION_APP_USER after running infra/postgres/create-app-user.sh
POSTGRES_USER=data-solution-2026_app
POSTGRES_PASSWORD=changeme
DATA_SOLUTION_DB=data-solution-2026

# Kafka broker (poller and controller). Requires kafka_default Docker network on Airflow.
KAFKA_HOST=kafka:9092

# Event controller → extract DAG (used by extractor_and_poller.controller when not in direct mode)
AIRFLOW_HOST=http://airflow-standalone:8080
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=changeme
EXTRACT_DAG_ID=openmeteo_daily_temperature_extract

# Optional override; default installs poller/extractor deps at container start (PoC only)
# _PIP_ADDITIONAL_REQUIREMENTS=requests>=2.32,<3 pandas>=2.2,<3 pyarrow>=16 jsonschema>=4 kafka-python psycopg[binary]
