# Copy to .env on NAS. Do not commit .env.
#
# Shared Postgres on BasNAS (container basnas_postgress, host port 5432).
# Airflow reaches it as basnas_postgress:5432 on Docker network immich_default.

# Admin login for basnas_postgress (not the poller app role).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_CONTAINER=basnas_postgress

DATA_SOLUTION_DB=data-solution-2026

# Application role (poller / Airflow). Created by: bash infra/postgres/create-app-user.sh
DATA_SOLUTION_APP_USER=data-solution-2026_app
DATA_SOLUTION_APP_PASSWORD=changeme

# Repo root (schema SQL path for create-app-user.sh)
DATA_SOLUTION_ROOT=../../
