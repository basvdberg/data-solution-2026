# Copy to .env on NAS. Do not commit .env.

# Bootstrap superuser for the container (not the poller app role).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
DATA_SOLUTION_DB=data-solution-2026
# Host port (5432 is often taken on QNAP; internal service stays postgres:5432)
POSTGRES_HOST_PORT=5433

# Application role (poller / Airflow). Created by: bash infra/postgres/create-app-user.sh
DATA_SOLUTION_APP_USER=data-solution-2026_app
DATA_SOLUTION_APP_PASSWORD=changeme

# Repo root (for schema init mount)
DATA_SOLUTION_ROOT=../../
